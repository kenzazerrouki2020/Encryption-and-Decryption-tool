import string

def encrypt(message, shift):
    alphabet = string.ascii_lowercase
    encrypt_message = ''
    dencrypt_message = ''

    choice = input('Do you want encrypt or decrypt? (1: encrypt / 2: decrypt): ')

    if choice == '1':
        for letter in message:
            if letter.lower() in alphabet:
                original_position = alphabet.index(letter.lower())
                new_position = (original_position + shift) % 26
                encrypt_letter = alphabet[new_position]

                if letter.isupper():
                    encrypt_letter = encrypt_letter.upper()

                encrypt_message += encrypt_letter
            else:
                encrypt_message += letter

        print("Encrypted message:", encrypt_message)

    else:
        for letter in message:
            if letter.lower() in alphabet:
                original_position = alphabet.index(letter.lower())
                new_position = (original_position - shift) % 26
                dencrypt_letter = alphabet[new_position]

                if letter.isupper():
                    dencrypt_letter = dencrypt_letter.upper()

                dencrypt_message += dencrypt_letter
            else:
                dencrypt_message += letter

        print("Decrypted message:", dencrypt_message)


user_message = input('Enter a message: ')
user_shift = int(input('Enter a shift number: '))

encrypt(message=user_message, shift=user_shift)
